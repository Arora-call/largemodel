# ============================================
# CodeForge Docker Compose 环境变量
# 复制此文件为 .env 并根据需要修改
# ============================================

# MySQL
MYSQL_ROOT_PASSWORD=123456
MYSQL_DATABASE=largemodel
MYSQL_PORT=3306

# Redis
REDIS_PORT=6379

# 服务端口映射
GATEWAY_PORT=8080
AUTH_PORT=8081
CODE_PORT=8082
KNOWLEDGE_PORT=8083
AGENT_PORT=8084
ADMIN_PORT=8085
FRONTEND_PORT=80

# AI API Key (必填 — 从 DeepSeek 或 OpenAI 获取)
OPENAI_API_KEY=sk-your-key-here
